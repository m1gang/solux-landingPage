---
const heroImages = [
  "https://images.unsplash.com/photo-1463173904305-ba479d2123b7?q=80&w=1916&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  "https://images.unsplash.com/photo-1509391366360-2e959784a276?q=80&w=1600&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?q=80&w=1600&auto=format&fit=crop",
];
---

<section class="px-container-padding mb-section-gap" data-animate>
  <div
    class="relative w-full h-[60vh] md:h-[75vh] clip-a clip-a-border p-[1px]"
  >
    <div class="absolute inset-[1px] overflow-hidden bg-surface clip-a-inner">
      <!-- Carousel slides -->
      <div
        class="absolute inset-0 hero-slide active"
        data-slide="0"
        style="background-image: url('https://images.unsplash.com/photo-1463173904305-ba479d2123b7?q=80&w=1916&auto=format&fit=crop'); background-size: cover; background-position: center;"
      >
      </div>
      <div
        class="absolute inset-0 hero-slide"
        data-slide="1"
        style="background-image: url('https://images.unsplash.com/photo-1509391366360-2e959784a276?q=80&w=1600&auto=format&fit=crop'); background-size: cover; background-position: center;"
      >
      </div>
      <div
        class="absolute inset-0 hero-slide"
        data-slide="2"
        style="background-image: url('https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?q=80&w=1600&auto=format&fit=crop'); background-size: cover; background-position: center;"
      >
      </div>

      <!-- Dark gradient overlay -->
      <div
        class="absolute inset-0 bg-gradient-to-l from-black/95 via-black/60 to-black/30 z-[2]"
      >
      </div>

      <!-- Vertical dot navigation - left side -->
      <div
        class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-20 flex flex-col gap-3"
      >
        <button class="hero-dot active" data-dot="0" aria-label="Imagen 1"
        ></button>
        <button class="hero-dot" data-dot="1" aria-label="Imagen 2"></button>
        <button class="hero-dot" data-dot="2" aria-label="Imagen 3"></button>
      </div>

      <!-- Text content -->
      <div
        class="absolute inset-0 p-6 md:p-16 flex flex-col justify-center max-w-4xl items-end text-right ml-auto z-10"
      >
        <h1
          class="font-display-lg text-display-lg text-white mb-6 leading-tight"
        >
          EFICIENCIA<br />
          <span
            class="font-headline-italic text-headline-italic text-accent italic"
            >Energética Industrial</span
          >
        </h1>
        <p
          class="font-body-lg text-body-lg text-on-surface-variant mb-10 max-w-xl max-md:text-base"
        >
          Diseñamos, proyectamos e instalamos sistemas fotovoltaicos a gran
          escala y soluciones de almacenamiento inteligente para plantas de
          manufactura y centros logísticos.
        </p>
        <div class="flex flex-wrap gap-4 justify-end">
          <button
            class="btn-accent border border-primary px-6 py-3 text-primary uppercase font-label-mono text-sm"
            >Solicitar Auditoría Técnica</button
          >
          <button
            class="border border-white/15 px-6 py-3 text-on-surface-variant hover:bg-white/5 hover:text-on-surface transition-all uppercase font-label-mono text-sm"
            >Descargar Dossier Corporativo</button
          >
        </div>
      </div>

      <!-- Notch categories -->
      <div
        class="absolute bottom-0 right-0 flex w-full md:w-auto md:min-w-[700px] bg-black/60 backdrop-blur-xl border-t border-l border-white/10 overflow-x-auto scrollbar-none z-10"
      >
        <span
          class="flex-1 text-center py-4 md:py-6 border-r border-white/10 font-label-mono text-[10px] uppercase tracking-[0.2em] text-white/80 whitespace-nowrap px-4"
          >Fotovoltaicos</span
        >
        <span
          class="flex-1 text-center py-4 md:py-6 border-r border-white/10 font-label-mono text-[10px] uppercase tracking-[0.2em] text-white/80 whitespace-nowrap px-4"
          >BESS</span
        >
        <span
          class="flex-1 text-center py-4 md:py-6 font-label-mono text-[10px] uppercase tracking-[0.2em] text-white/80 whitespace-nowrap px-4"
          >Eficiencia Energética</span
        >
      </div>
    </div>
  </div>
</section>

<style>
  .hero-slide {
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
  }
  .hero-slide.active {
    opacity: 1;
  }
  .hero-dot {
    width: 12px;
    height: 12px;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-dot::after {
    content: '';
    width: 6px;
    height: 6px;
    background: transparent;
    transition: background 0.3s ease;
  }
  .hero-dot.active {
    border-color: #3b82f6;
  }
  .hero-dot.active::after {
    background: #3b82f6;
  }
</style>

<script>
  const slides = document.querySelectorAll(".hero-slide");
  const dots = document.querySelectorAll(".hero-dot");

  let autoPlay;

  function goToSlide(index) {
    slides.forEach((s, i) => s.classList.toggle("active", i === index));
    dots.forEach((d, i) => d.classList.toggle("active", i === index));
  }

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      const index = parseInt(dot.getAttribute("data-dot"));
      goToSlide(index);
      clearInterval(autoPlay);
      autoPlay = setInterval(() => {
        const current = Array.from(dots).findIndex(d => d.classList.contains("active"));
        const next = (current + 1) % slides.length;
        goToSlide(next);
      }, 6000);
    });
  });

  let current = 0;
  autoPlay = setInterval(() => {
    current = (current + 1) % slides.length;
    goToSlide(current);
  }, 6000);
</script>
