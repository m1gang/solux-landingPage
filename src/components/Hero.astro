---
import { Image } from "astro:assets";
import hero from "../assets/images/hero-1.webp";
---

<section class="px-container-padding mb-section-gap" data-animate>
  <div
    class="relative w-full h-[60vh] md:h-[75vh] clip-a clip-a-border p-[1px]"
  >
    <div class="absolute inset-[1px] overflow-hidden bg-[#0d0d0d] clip-a-inner">
      <Image
        src={hero}
        alt="Instalación fotovoltaica industrial"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div
        class="absolute inset-0 bg-gradient-to-l from-[#0d0d0d]/95 via-[#0d0d0d]/60 to-[#0d0d0d]/30"
      >
      </div>
      <div
        class="absolute inset-0 p-6 md:p-16 flex flex-col justify-center max-w-4xl items-end text-right ml-auto"
      >
        <h1
          class="font-display-lg text-display-lg text-white mb-6 leading-tight"
        >
          EFICIENCIA<br />
          <span class="text-headline-italic text-orange italic"
            >Energética Industrial</span
          >
        </h1>
        <p
          class="font-body-lg text-body-lg text-on-surface-variant mb-10 max-w-xl max-md:text-base"
        >
          Diseñamos, proyectamos e instalamos sistemas fotovoltaicos a gran
          escala y soluciones de almacenamiento inteligente para plantas de
          manufactura y centros logísticos.
        </p>
        <div class="flex flex-wrap gap-4 justify-end">
          <button
            class="btn-audit border border-primary px-6 py-3 text-primary uppercase font-label-mono text-sm"
            >Solicitar Auditoría Técnica</button
          >
          <button
            class="border border-white/20 px-6 py-3 hover:bg-white/10 transition-colors uppercase font-label-mono text-sm"
            >Descargar Dossier Corporativo</button
          >
        </div>
      </div>
      <div
        class="absolute bottom-0 right-0 flex w-full md:w-auto md:min-w-[700px] bg-black/60 backdrop-blur-xl border-t border-l border-white/10 overflow-x-auto scrollbar-none"
      >
        <span
          class="flex-1 text-center py-4 md:py-6 border-r border-white/10 font-label-mono text-[10px] uppercase tracking-[0.2em] text-white whitespace-nowrap px-4"
          >Fotovoltaicos</span
        >
        <span
          class="flex-1 text-center py-4 md:py-6 border-r border-white/10 font-label-mono text-[10px] uppercase tracking-[0.2em] text-white whitespace-nowrap px-4"
          >BESS</span
        >
        <span
          class="flex-1 text-center py-4 md:py-6 font-label-mono text-[10px] uppercase tracking-[0.2em] text-white whitespace-nowrap px-4"
          >Eficiencia Energética</span
        >
      </div>
    </div>
  </div>
</section>
