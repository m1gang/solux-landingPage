---
<section class="px-container-padding mb-section-gap" id="contact">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
    <div>
      <h2 class="font-headline-xl text-headline-xl text-white mb-8">Iniciar Auditoría Técnica</h2>
      <p class="text-on-surface-variant mb-12">Contacte con nuestro equipo de ingeniería para analizar el perfil energético de su planta y el potencial de independencia de red.</p>
      <div class="space-y-6 mb-12">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-white/5 flex items-center justify-center text-primary border border-white/10">
            <span class="material-symbols-outlined">location_on</span>
          </div>
          <span>Zona Industrial 4, Parque Tecnológico, MX</span>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-white/5 flex items-center justify-center text-primary border border-white/10">
            <span class="material-symbols-outlined">call</span>
          </div>
          <span>+52 (555) SOLUX-HQ</span>
        </div>
      </div>
      <div class="aspect-video bg-surface-container-high border border-white/10 relative overflow-hidden">
        <div class="absolute inset-0" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px); opacity: 0.2;"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center">
            <span class="material-symbols-outlined text-primary text-4xl mb-2">engineering</span>
            <p class="font-label-mono text-[10px] uppercase text-on-surface-variant">Centro Logístico Global - Plano de Ingeniería</p>
          </div>
        </div>
      </div>
    </div>
    <div class="clip-angular clip-angular-border">
      <div class="bg-surface-container-high p-10 border-t-4 border-t-primary clip-inner h-full">
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
              <label class="font-label-mono text-[10px] uppercase text-on-surface-variant">Nombre Completo</label>
              <input
                type="text"
                placeholder="Ej. Juan Pérez"
                class="w-full bg-[#1a1a1a] border border-white/10 text-white placeholder-gray-400 focus:border-orange focus:ring-0 focus:outline-none p-3 transition-colors"
              />
            </div>
            <div class="flex flex-col gap-2">
              <label class="font-label-mono text-[10px] uppercase text-on-surface-variant">Correo Corporativo</label>
              <input
                type="email"
                placeholder="juan@empresa.com"
                class="w-full bg-[#1a1a1a] border border-white/10 text-white placeholder-gray-400 focus:border-orange focus:ring-0 focus:outline-none p-3 transition-colors"
              />
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-mono text-[10px] uppercase text-on-surface-variant">Tipo de Planta Industrial</label>
            <select class="w-full bg-[#1a1a1a] border border-white/10 text-white focus:border-orange focus:ring-0 focus:outline-none p-3 transition-colors">
              <option>Planta de Manufactura</option>
              <option>Logística / Almacén</option>
              <option>Centro de Datos</option>
              <option>Procesamiento Agrícola</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-mono text-[10px] uppercase text-on-surface-variant">Consumo Eléctrico Mensual (USD/MXN)</label>
            <select class="w-full bg-[#1a1a1a] border border-white/10 text-white focus:border-orange focus:ring-0 focus:outline-none p-3 transition-colors">
              <option>$10,000 - $50,000</option>
              <option>$50,000 - $100,000</option>
              <option>+$100,000</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-mono text-[10px] uppercase text-on-surface-variant">Mensaje o Detalles del Proyecto</label>
            <textarea
              placeholder="Describa brevemente sus necesidades energéticas..."
              class="w-full bg-[#1a1a1a] border border-white/10 text-white placeholder-gray-400 focus:border-orange focus:ring-0 focus:outline-none p-3 min-h-[120px] transition-colors"
            ></textarea>
          </div>
          <button type="submit" class="bg-primary text-black font-label-mono py-4 text-lg w-full uppercase hover:bg-white transition-colors">Enviar Solicitud a Ingeniería</button>
        </form>
      </div>
    </div>
  </div>
</section>
