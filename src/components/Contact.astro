---
<section class="px-container-padding mb-section-gap" id="contact">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start" data-animate>
    <div>
      <h2 class="font-headline-xl text-headline-xl text-white mb-8">Iniciar Auditoría Técnica</h2>
      <p class="text-on-surface-variant mb-12">Contacte con nuestro equipo de ingeniería para analizar el perfil energético de su planta y el potencial de independencia de red.</p>
      <div class="space-y-6 mb-12">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-white/5 flex items-center justify-center text-primary border border-white/10">
            <span class="material-symbols-outlined">location_on</span>
          </div>
          <span class="text-on-surface-variant">Zona Industrial 4, Parque Tecnológico, MX</span>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-white/5 flex items-center justify-center text-primary border border-white/10">
            <span class="material-symbols-outlined">call</span>
          </div>
          <span class="text-on-surface-variant">+52 (555) SOLUX-HQ</span>
        </div>
      </div>
      <div class="aspect-video bg-surface-container-high border border-white/10 relative overflow-hidden">
        <div class="absolute inset-0 pointer-events-none" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px); opacity: 0.2;"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center">
            <span class="material-symbols-outlined text-primary text-4xl mb-2">engineering</span>
            <p class="font-label-mono text-[10px] uppercase text-on-surface-variant">Centro Logístico Global - Plano de Ingeniería</p>
          </div>
        </div>
      </div>
    </div>
    <div class="clip-a clip-a-border">
      <div class="bg-surface-container-high p-6 md:p-10 border-t-4 border-t-accent clip-a-inner h-full">
        <form class="space-y-5 md:space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
              <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="nombre">Nombre Completo</label>
              <input id="nombre" type="text" placeholder="Ej. Juan Pérez" class="w-full bg-surface border border-white/10 text-on-surface placeholder-on-surface-variant/50 focus:border-accent focus:ring-0 focus:outline-none p-3 transition-colors" />
            </div>
            <div class="flex flex-col gap-2">
              <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="email">Correo Corporativo</label>
              <input id="email" type="email" placeholder="juan@empresa.com" class="w-full bg-surface border border-white/10 text-on-surface placeholder-on-surface-variant/50 focus:border-accent focus:ring-0 focus:outline-none p-3 transition-colors" />
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="tipo-planta">Tipo de Planta Industrial</label>
            <select id="tipo-planta" class="w-full bg-surface border border-white/10 text-on-surface focus:border-accent focus:ring-0 focus:outline-none p-3 transition-colors">
              <option>Planta de Manufactura</option>
              <option>Logística / Almacén</option>
              <option>Centro de Datos</option>
              <option>Procesamiento Agrícola</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="consumo">Consumo Eléctrico Mensual (USD/MXN)</label>
            <select id="consumo" class="w-full bg-surface border border-white/10 text-on-surface focus:border-accent focus:ring-0 focus:outline-none p-3 transition-colors">
              <option>$10,000 - $50,000</option>
              <option>$50,000 - $100,000</option>
              <option>+$100,000</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="mensaje">Mensaje o Detalles del Proyecto</label>
            <textarea id="mensaje" placeholder="Describa brevemente sus necesidades energéticas..." class="w-full bg-surface border border-white/10 text-on-surface placeholder-on-surface-variant/50 focus:border-accent focus:ring-0 focus:outline-none p-3 min-h-[120px] transition-colors"></textarea>
          </div>
          <button type="submit" class="btn-accent bg-primary text-on-primary font-label-mono py-4 text-lg w-full uppercase border border-primary transition-colors">Enviar Solicitud a Ingeniería</button>
        </form>
      </div>
    </div>
  </div>
</section>
