---
---

<section class="px-container-padding mb-section-gap" id="contact">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start" data-animate>
    <div>
      <span class="font-label-mono text-label-mono text-primary uppercase mb-2 block">Atención Directa de Ingeniería</span>
      <h2 class="font-headline-xl text-headline-xl text-white mb-6">Iniciar Auditoría Técnica</h2>
      <p class="text-on-surface-variant mb-10 text-body-md leading-relaxed">
        Contacte con nuestro equipo de ingeniería para analizar el perfil energético de su planta y el potencial de independencia de red.
      </p>

      <div class="space-y-6 mb-10">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-white/5 flex items-center justify-center text-primary border border-white/10">
            <span class="material-symbols-outlined">location_on</span>
          </div>
          <span class="text-on-surface-variant font-body-md">Zona Industrial 4, Parque Tecnológico, MX</span>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-white/5 flex items-center justify-center text-primary border border-white/10">
            <span class="material-symbols-outlined">call</span>
          </div>
          <span class="text-on-surface-variant font-body-md">+52 (555) SOLUX-HQ</span>
        </div>
      </div>

      <!-- Interactive / Technical Blueprint SVG Container -->
      <div class="clip-b clip-b-border p-[1px] relative overflow-hidden">
        <div class="bg-surface-container-high clip-b-inner relative aspect-video flex flex-col justify-between p-6 overflow-hidden group">
          <!-- CAD Grid Background -->
          <div
            class="absolute inset-0 pointer-events-none opacity-20"
            style="background-image: linear-gradient(rgba(59, 130, 246, 0.4) 1px, transparent 1px), linear-gradient(90deg, rgba(59, 130, 246, 0.4) 1px, transparent 1px); background-size: 20px 20px;"
          ></div>

          <!-- Technical Schematic Overlay SVG -->
          <svg class="absolute inset-0 w-full h-full opacity-40 group-hover:opacity-60 transition-opacity duration-500" viewBox="0 0 600 350" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Outer Blueprint Outline -->
            <rect x="20" y="20" width="560" height="310" stroke="#3b82f6" stroke-width="1.5" stroke-dasharray="6 4" />
            <!-- Building Layout Zones -->
            <rect x="50" y="50" width="220" height="150" stroke="#3b82f6" stroke-width="2" fill="rgba(59, 130, 246, 0.05)" />
            <rect x="300" y="50" width="250" height="230" stroke="#FF9F00" stroke-width="2" fill="rgba(255, 159, 0, 0.05)" />
            <rect x="50" y="220" width="220" height="60" stroke="#3b82f6" stroke-width="1" stroke-dasharray="3 3" />

            <!-- Solar Array Grid Markers -->
            <g stroke="#3b82f6" stroke-width="0.8" opacity="0.6">
              <line x1="60" y1="70" x2="250" y2="70" />
              <line x1="60" y1="90" x2="250" y2="90" />
              <line x1="60" y1="110" x2="250" y2="110" />
              <line x1="60" y1="130" x2="250" y2="130" />
              <line x1="60" y1="150" x2="250" y2="150" />
              <line x1="60" y1="170" x2="250" y2="170" />
            </g>

            <!-- BESS Battery Container Graphic -->
            <g stroke="#FF9F00" stroke-width="1.2">
              <rect x="330" y="80" width="80" height="40" rx="0" fill="rgba(255, 159, 0, 0.1)" />
              <rect x="440" y="80" width="80" height="40" rx="0" fill="rgba(255, 159, 0, 0.1)" />
              <rect x="330" y="140" width="80" height="40" rx="0" fill="rgba(255, 159, 0, 0.1)" />
              <rect x="440" y="140" width="80" height="40" rx="0" fill="rgba(255, 159, 0, 0.1)" />
            </g>

            <!-- Connection Vectors / Energy Lines -->
            <path d="M 270 125 L 300 125" stroke="#3b82f6" stroke-width="2" marker-end="url(#arrow)" />
            <path d="M 420 180 L 420 220 L 270 220" stroke="#FF9F00" stroke-width="1.5" stroke-dasharray="4 2" />

            <!-- Technical Crosshairs & Coordinates -->
            <circle cx="270" cy="125" r="4" fill="#3b82f6" />
            <circle cx="420" cy="180" r="4" fill="#FF9F00" />
            <text x="30" y="15" fill="#3b82f6" font-family="monospace" font-size="10">CAD REF: SOL-9042-HQ</text>
            <text x="450" y="315" fill="#FF9F00" font-family="monospace" font-size="10">GRID SYNC: 100%</text>
          </svg>

          <!-- Top Schematic Header -->
          <div class="relative z-10 flex justify-between items-start">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-xl">engineering</span>
              <span class="font-label-mono text-[10px] uppercase tracking-widest text-primary font-bold">
                DIAGRAMA CAD / ESQUEMA TÉCNICO
              </span>
            </div>
            <span class="font-label-mono text-[9px] uppercase px-2 py-0.5 bg-primary/20 text-primary border border-primary/30">
              ACTIVO
            </span>
          </div>

          <!-- Bottom Blueprint Info -->
          <div class="relative z-10 pt-4 border-t border-white/10 flex justify-between items-end">
            <div>
              <p class="font-headline-lg text-sm text-white font-bold uppercase tracking-wider">
                Centro Logístico Global
              </p>
              <span class="font-label-mono text-[10px] text-on-surface-variant block">
                Plano de Subestación y Arreglo Solar 2.4 MWp
              </span>
            </div>
            <span class="font-label-mono text-[10px] text-accent font-bold">
              ESCALA 1:500
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact / RFQ Form Card -->
    <div class="clip-a clip-a-border">
      <div class="bg-surface-container-high p-6 md:p-10 border-t-4 border-t-accent clip-a-inner h-full">
        <form class="space-y-5 md:space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
              <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="nombre">Nombre Completo</label>
              <input id="nombre" type="text" placeholder="Ej. Juan Pérez" class="w-full bg-surface border border-white/10 text-on-surface placeholder-on-surface-variant/50 focus:border-accent focus:ring-0 focus:outline-none p-3 transition-colors" />
            </div>
            <div class="flex flex-col gap-2">
              <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="email">Correo Corporativo</label>
              <input id="email" type="email" placeholder="juan@empresa.com" class="w-full bg-surface border border-white/10 text-on-surface placeholder-on-surface-variant/50 focus:border-accent focus:ring-0 focus:outline-none p-3 transition-colors" />
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="tipo-planta">Tipo de Planta Industrial</label>
            <select id="tipo-planta" class="w-full bg-surface border border-white/10 text-on-surface focus:border-accent focus:ring-0 focus:outline-none p-3 transition-colors">
              <option>Planta de Manufactura</option>
              <option>Logística / Almacén</option>
              <option>Centro de Datos</option>
              <option>Procesamiento Agrícola</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="consumo">Consumo Eléctrico Mensual (USD/MXN)</label>
            <select id="consumo" class="w-full bg-surface border border-white/10 text-on-surface focus:border-accent focus:ring-0 focus:outline-none p-3 transition-colors">
              <option>$10,000 - $50,000</option>
              <option>$50,000 - $100,000</option>
              <option>+$100,000</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="font-label-mono text-[10px] uppercase text-on-surface-variant" for="mensaje">Mensaje o Detalles del Proyecto</label>
            <textarea id="mensaje" placeholder="Describa brevemente sus necesidades energéticas..." class="w-full bg-surface border border-white/10 text-on-surface placeholder-on-surface-variant/50 focus:border-accent focus:ring-0 focus:outline-none p-3 min-h-[120px] transition-colors"></textarea>
          </div>

          <!-- Submit Button with Geometric Cut Style -->
          <button
            type="submit"
            class="btn-geo bg-primary text-white font-label-mono py-4 text-base md:text-lg w-full uppercase border border-primary transition-all duration-300 hover:bg-accent hover:border-accent hover:text-black font-bold tracking-wider cursor-pointer"
          >
            Enviar Solicitud a Ingeniería
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
