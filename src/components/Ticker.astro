---
<section class="py-12 md:py-16 bg-surface border-y border-white/5 mb-section-gap overflow-hidden relative" data-animate>
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.5) 39px, rgba(255,255,255,0.5) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.5) 39px, rgba(255,255,255,0.5) 40px);"></div>
  <div class="flex gap-16 md:gap-20 items-center whitespace-nowrap opacity-30 px-container-padding animate-marquee relative z-10" style="width: max-content;">
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold text-on-surface-variant">CATERPILLAR</span>
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold text-on-surface-variant">SIEMENS</span>
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold text-on-surface-variant">SCHNEIDER</span>
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold text-on-surface-variant">ABB</span>
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold text-on-surface-variant">GENERAL ELECTRIC</span>
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold ml-16 md:ml-20 text-on-surface-variant">CATERPILLAR</span>
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold text-on-surface-variant">SIEMENS</span>
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold text-on-surface-variant">SCHNEIDER</span>
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold text-on-surface-variant">ABB</span>
    <span class="font-headline-lg text-2xl md:text-headline-lg font-bold text-on-surface-variant">GENERAL ELECTRIC</span>
  </div>
</section>
