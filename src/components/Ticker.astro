---
<section class="py-16 bg-surface-container-low border-y border-white/5 mb-section-gap overflow-hidden relative">
  <div class="absolute inset-0 pointer-events-none" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.02) 39px, rgba(255,255,255,0.02) 40px); opacity: 0.1;"></div>
  <div class="flex gap-20 items-center whitespace-nowrap opacity-40 px-container-padding animate-marquee relative z-10" style="width: max-content;">
    <span class="font-headline-lg text-headline-lg font-bold">CATERPILLAR</span>
    <span class="font-headline-lg text-headline-lg font-bold">SIEMENS</span>
    <span class="font-headline-lg text-headline-lg font-bold">SCHNEIDER</span>
    <span class="font-headline-lg text-headline-lg font-bold">ABB</span>
    <span class="font-headline-lg text-headline-lg font-bold">GENERAL ELECTRIC</span>
    <span class="font-headline-lg text-headline-lg font-bold ml-20">CATERPILLAR</span>
    <span class="font-headline-lg text-headline-lg font-bold">SIEMENS</span>
    <span class="font-headline-lg text-headline-lg font-bold">SCHNEIDER</span>
    <span class="font-headline-lg text-headline-lg font-bold">ABB</span>
    <span class="font-headline-lg text-headline-lg font-bold">GENERAL ELECTRIC</span>
  </div>
</section>
