// Duplicamos el arreglo para lograr el bucle infinito sin cortes
const marqueeItems = [...brands, ...brands];
---

<section
  class="ticker-wrapper py-10 md:py-14 bg-surface border-y border-white/5 mb-section-gap overflow-hidden relative"
  data-animate
>
  <!-- Fondo reticulado decorativo -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.03]"
    style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.5) 39px, rgba(255,255,255,0.5) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.5) 39px, rgba(255,255,255,0.5) 40px);"
  >
  </div>

  <!-- Difuminados laterales para suavizar bordes -->
  <div
    class="absolute left-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-r from-surface to-transparent z-20 pointer-events-none"
  >
  </div>
  <div
    class="absolute right-0 top-0 bottom-0 w-16 md:w-32 bg-gradient-to-l from-surface to-transparent z-20 pointer-events-none"
  >
  </div>

  <!-- Pista de animación continua -->
  <div
    class="ticker-track flex gap-12 md:gap-24 items-center whitespace-nowrap relative z-10"
  >
    {
      marqueeItems.map((brand) => (
        <div class="ticker-brand-item flex flex-col items-center justify-center gap-3 cursor-pointer group/brand flex-shrink-0">
          <div
            class="w-12 h-12 md:w-16 md:h-16 flex items-center justify-center text-on-surface-variant/40 group-hover/brand:text-[#FFFFFF] transition-colors duration-300"
            set:html={brand.svg}
          />
          <span class="font-label-mono text-[11px] font-bold tracking-[0.2em] uppercase text-on-surface-variant/40 group-hover/brand:text-[#FFFFFF] transition-colors duration-300">
            {brand.name}
          </span>
        </div>
      ))
    }
  </div>
</section>

<style>
  @keyframes smooth-marquee {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }

  .ticker-track {
    width: max-content;
    animation: smooth-marquee 30s linear infinite;
    will-change: transform;
  }

  /* Al colocar el cursor sobre cualquier parte del componente ticker, la animación se detiene */
  .ticker-wrapper:hover .ticker-track {
    animation-play-state: paused !important;
  }

  /* Transición rápida para los SVGs e iconos */
  .ticker-brand-item svg {
    transition: color 0.3s ease;
  }
</style>
