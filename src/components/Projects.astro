---
<section class="px-container-padding mb-section-gap" id="projects">
  <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-4" data-animate>
    <h2 class="font-headline-xl text-headline-xl text-white uppercase tracking-tighter">Despliegues Destacados</h2>
    <a href="#" class="font-label-mono text-label-mono text-primary uppercase border-b border-primary">Ver Casos de Éxito</a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-animate="stagger">
    <div class="group cursor-pointer">
      <div class="aspect-[16/9] relative clip-b-border p-[1px] clip-b">
        <div class="bg-surface-container-high h-full w-full relative overflow-hidden clip-b-inner">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1509391366360-2e959784a276?q=80&w=1200&auto=format&fit=crop');"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 to-transparent"></div>
          <div class="absolute bottom-6 md:bottom-10 left-4 md:left-8 pr-4 md:pr-8 z-10">
            <h4 class="text-white text-headline-lg text-xl md:text-headline-lg mb-1">Planta Logística Norte</h4>
            <span class="font-label-mono text-[10px] text-primary uppercase">1.2 MWp Capacidad Instalada</span>
          </div>
        </div>
      </div>
    </div>
    <div class="group cursor-pointer">
      <div class="aspect-[16/9] relative clip-c-border p-[1px] clip-c">
        <div class="bg-surface-container-high h-full w-full relative overflow-hidden clip-c-inner">
          <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1497435334941-8c899ee9e8e9?q=80&w=1200&auto=format&fit=crop');"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 to-transparent"></div>
          <div class="absolute bottom-6 md:bottom-10 left-4 md:left-8 pr-4 md:pr-8 z-10">
            <h4 class="text-white text-headline-lg text-xl md:text-headline-lg mb-1">Fábrica de Alimentos NutriCorp</h4>
            <span class="font-label-mono text-[10px] text-secondary uppercase">850 kWp + 2MWh Almacenamiento BESS</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
