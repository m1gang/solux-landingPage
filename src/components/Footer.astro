---
import { Image } from "astro:assets";
import logo from "../assets/icons/logo-solux.svg";
---

<footer class="bg-surface-dim border-t border-white/5 py-20 md:py-section-gap relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.5) 39px, rgba(255,255,255,0.5) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.5) 39px, rgba(255,255,255,0.5) 40px);"></div>
  <div class="flex flex-col md:flex-row justify-between items-start px-6 md:px-container-padding max-w-7xl mx-auto relative z-10">
    <div class="mb-10 md:mb-0">
      <Image src={logo} alt="SOLUX - Energía Industrial Inteligente" width={200} height={80} class="mb-6" loading="lazy" decoding="async" />
      <p class="font-body-md text-body-md text-on-surface-variant max-w-xs leading-relaxed">
        &copy; 2026 SOLUX Industrial. Todos los derechos reservados. Soluciones de Energía Certificadas ISO 9001 &amp; 14001.
      </p>
    </div>
    <div class="grid grid-cols-2 gap-16">
      <div class="flex flex-col gap-3">
        <span class="font-label-mono text-[10px] uppercase text-on-surface-variant/50 mb-1 tracking-[0.15em]">Navegación</span>
        <a href="#" class="font-label-mono text-[12px] text-on-surface-variant hover:text-primary transition-colors uppercase tracking-widest">Servicios</a>
        <a href="#" class="font-label-mono text-[12px] text-on-surface-variant hover:text-primary transition-colors uppercase tracking-widest">Proyectos</a>
        <a href="#" class="font-label-mono text-[12px] text-on-surface-variant hover:text-primary transition-colors uppercase tracking-widest">Especificaciones</a>
      </div>
      <div class="flex flex-col gap-3">
        <span class="font-label-mono text-[10px] uppercase text-on-surface-variant/50 mb-1 tracking-[0.15em]">Legal</span>
        <a href="#" class="font-label-mono text-[12px] text-on-surface-variant hover:text-primary transition-colors uppercase tracking-widest">Privacidad</a>
        <a href="#" class="font-label-mono text-[12px] text-on-surface-variant hover:text-primary transition-colors uppercase tracking-widest">Términos</a>
        <a href="#" class="font-label-mono text-[12px] text-on-surface-variant hover:text-primary transition-colors uppercase tracking-widest">Soporte</a>
      </div>
    </div>
  </div>
</footer>
