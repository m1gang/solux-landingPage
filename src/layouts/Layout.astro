---
import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/500.css";
import "@fontsource/geist-sans/600.css";
import "@fontsource/geist-sans/700.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "SOLUX – Energía Industrial Inteligente",
  description = "Diseñamos, proyectamos e instalamos sistemas fotovoltaicos a gran escala y soluciones de almacenamiento inteligente para plantas de manufactura y centros logísticos.",
  ogImage = "/og-solux.jpg",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/solux.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://solux.energy" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Newsreader:ital,wght@1,400&family=Space+Grotesk:wght@500&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-black text-on-surface font-body-lg min-h-screen relative overflow-x-hidden"
  >
    <div
      class="fixed inset-0 pointer-events-none z-0"
      style="background-color: rgb(5, 5, 12); opacity: 0.8; background-image: radial-gradient(rgb(247, 141, 69) 1px, rgb(5, 5, 12) 1px); background-size: 10px 10px; mask-image: radial-gradient(rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 75%); mask-size: 100% 100%; mask-repeat: no-repeat;"
    >
    </div>

    <slot />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
      );

      document
        .querySelectorAll("[data-animate]")
        .forEach((el) => observer.observe(el));

      document.addEventListener("astro:after-swap", () => {
        document
          .querySelectorAll("[data-animate]")
          .forEach((el) => observer.observe(el));
      });
    </script>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  *,
  *::before,
  *::after {
    border-radius: 0 !important;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .animate-marquee {
    animation: marquee-scroll 30s linear infinite;
  }

  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }

  @media (max-width: 768px) {
    :root {
      --container-padding: 24px;
    }
  }

  /* --- Clip-path variants --- */

  :root {
    --clip-a: polygon(0 0, 90% 0, 100% 10%, 100% 100%, 10% 100%, 0 90%);
    --clip-b: polygon(0 0, 85% 0, 100% 15%, 100% 100%, 0 100%);
    --clip-c: polygon(0 0, 100% 0, 100% 100%, 15% 100%, 0 85%);
  }

  .clip-a {
    clip-path: var(--clip-a);
  }
  .clip-b {
    clip-path: var(--clip-b);
  }
  .clip-c {
    clip-path: var(--clip-c);
  }

  .clip-a-inner {
    clip-path: var(--clip-a);
    height: 100%;
    width: 100%;
  }
  .clip-b-inner {
    clip-path: var(--clip-b);
    height: 100%;
    width: 100%;
  }
  .clip-c-inner {
    clip-path: var(--clip-c);
    height: 100%;
    width: 100%;
  }

  .clip-a-border {
    position: relative;
  }
  .clip-a-border::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.1);
    clip-path: var(--clip-a);
    z-index: -1;
    padding: 1px;
  }

  .clip-b-border {
    position: relative;
  }
  .clip-b-border::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.1);
    clip-path: var(--clip-b);
    z-index: -1;
    padding: 1px;
  }

  .clip-c-border {
    position: relative;
  }
  .clip-c-border::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.1);
    clip-path: var(--clip-c);
    z-index: -1;
    padding: 1px;
  }

  /* --- Scroll entrance animations --- */

  [data-animate] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s ease-out,
      transform 0.7s ease-out;
  }
  [data-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  [data-animate="stagger"] > * {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s ease-out,
      transform 0.6s ease-out;
  }
  [data-animate="stagger"].is-visible > *:nth-child(1) {
    transition-delay: 0s;
  }
  [data-animate="stagger"].is-visible > *:nth-child(2) {
    transition-delay: 0.1s;
  }
  [data-animate="stagger"].is-visible > *:nth-child(3) {
    transition-delay: 0.2s;
  }
  [data-animate="stagger"].is-visible > *:nth-child(4) {
    transition-delay: 0.3s;
  }
  [data-animate="stagger"].is-visible > * {
    opacity: 1;
    transform: translateY(0);
  }

  /* --- Navbar scroll state --- */

  .nav-scrolled {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    margin-left: 0.75rem;
    margin-right: 0.75rem;
    width: calc(100% - 12px);
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  @media (min-width: 768px) {
    .nav-scrolled {
      margin-left: 1.5rem;
      margin-right: 1.5rem;
      width: calc(100% - 48px);
    }
  }

  /* --- Button micro-interactions --- */

  .btn-audit {
    position: relative;
    overflow: hidden;
    transition:
      color 0.3s ease,
      background-color 0.3s ease;
  }
  .btn-audit::before {
    content: "";
    position: absolute;
    inset: 0;
    background: #ff9f00;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: -1;
  }
  .btn-audit:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }
  .btn-audit:hover {
    color: #000;
    border-color: #ff9f00;
  }
</style>
